# ============================================================
# FlowOS Environment Configuration
# Copy to .env and fill in values. NEVER commit the real .env.
# ============================================================

# --- Core ---
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (PostgreSQL 15) ---
DATABASE_URL=postgresql://flowos:flowos_dev_password@localhost:5432/flowos?schema=public

# --- Redis (cache + sessions + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Object Storage (MinIO locally, S3 in production) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=flowos-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Search (Meilisearch) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey_change_me

# --- Auth ---
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# SAML (optional)
SAML_ENTRY_POINT=
SAML_ISSUER=flowos
SAML_CERT=

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FlowOS <noreply@flowos.local>"

# --- AI (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# --- External APIs ---
EXCHANGE_RATE_API_KEY=

# --- Google Sheets import (service account, read-only) ---
# Paste the ENTIRE downloaded service-account JSON key as a single-line string.
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY=

# --- Payments (placeholder) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Push notifications ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Observability ---
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Rate limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
