# Praeto Sheets Sync — Backend Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

PORT=3001
NODE_ENV=development

# Google Cloud service account (console.cloud.google.com → IAM & Admin → Service Accounts)
# Paste the ENTIRE downloaded JSON key file as a single-line string.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"...", ...}

# URL — update for production
FRONTEND_URL=https://pmtool-4-praeto.vercel.app
