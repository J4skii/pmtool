{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "Praeto Projects.dc.html", "use": "@vercel/static" },
    { "src": "support.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/health", "dest": "backend/server.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
